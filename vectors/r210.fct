# Set all inputs to inactive and use direct set and clear to configure flip-flop
# Drive AR Direct Set input active
output-drive='---1101-1010110111---111111111111111'
# Drive AR Direct Set input inactive and load the '1' output
output-drive='---11L1-1010-11111---111111111111111'

