##################################################################
################  Transfer to PC Flip Flop Tests  ################
##################################################################
## Transfer MB to PC
# 1. Clear the PC
# Let's clear the PC flip-flop with the direct clear input
# Drive CV Direct Clear input active, check both outputs
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
vector='-------11111111110---11111--11111111'
# Drive CV Direct Clear input inactive, check both outputs
vector='-------11111111111---111110101111111'

# 2. Set the MB flip flop so that we try passing a logic '1' to PC
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive the DM Level Input active
vector='-------11111111111---11111--01111111'
# Drive the DS Pulse Input active, flip-flip should be set
vector='---0-1-11111111111---11111--01110111'
# Drive the DS Pulse Input inactive, check for no change on the outputs
vector='---0-1-11111111111---11111--01111111'
# Drive the DM Level Input inactive, check for no change on the outputs
vector='---0-1-11111111111---11111--11111111'

# 3. Clock MB into PC with falling edge on DA
#    Note: Hardware is modified to allow card pin DA to be driven by CS
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive DA(via CS channel) active, check both outputs
vector='---0-1-11111111111---11111--11111111'
# Drive DA(via CS channel) inactive, check both outputs
vector='---0-1-11111110111---111111011111111'

# 4. Clear the MB flip flop so that we can try passing a logic '0' to PC
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive CU Direct Clear input active, check both outputs
vector='-------11111111101---11111--11111111'
# Drive CU Direct Clear input inactive, check both outputs
vector='---1-0-11111111111---11111--11111111'

# 5. Clock MB into PC with falling edge on DA
#    Note: Hardware is modified to allow card pin DA to be driven by CS
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive DA(via CS channel) active, check both outputs
vector='---1-0-11111110111---11111--11111111'
# Drive DA(via CS channel) inactive, check both outputs
vector='---1-0-11111111111---111110101111111'


###################################################################
################  Transfer to MA Flip Flop  Tests  ################
###################################################################

#### Transfer MB to MA
# 1. Clear the MA
# Let's clear the MA flip-flop with the direct clear input
# Drive CJ Direct Clear input active, check both outputs
vector='-------01111111111---11111--11111111'
# Drive CJ Direct Clear input inactive, check both outputs
vector='----1-011111111111---11111--11111111'

# 2. Set the MB flip flop so that we try passing a logic '1' to MA
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive the DM Level Input active
vector='-------11111111111---11111--01111111'
# Drive the DS Pulse Input active, flip-flip should be set
vector='---0-1-11111111111---11111--01110111'
# Drive the DS Pulse Input inactive, check for no change on the outputs
vector='---0-1-11111111111---11111--01111111'
# Drive the DM Level Input inactive, check for no change on the outputs
vector='---0-1-11111111111---11111--11111111'

# 3. Clock MB into MA with falling edge on CN
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive CN active, check both outputs
vector='---001111110111111---11111--11111111'
# Drive CN inactive, check both outputs
vector='---001111111111111---11111--01111111'

# 4. Clear the MB flip flop so that we can try passing a logic '0' to MA
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive CU Direct Clear input active, check both outputs
vector='-------11111111101---11111--11111111'
# Drive CU Direct Clear input inactive, check both outputs
vector='---1-0-11111111111---11111--11111111'

# 5. Clock MB into MA with falling edge on DA
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive DA(via CS channel) active, check both outputs
vector='---110011110111111---11111--11111111'
# Drive DA(via CS channel) inactive, check both outputs
vector='---110011111111111---11111--01111111'


#### Transfer PC to MA
# 1. Clear the MA
# Let's clear the MA flip-flop with the direct clear input
# Drive CJ Direct Clear input active, check both outputs
vector='-------01111111111---11111--11111111'
# Drive CJ Direct Clear input inactive, check both outputs
vector='----1-011111111111---11111--11111111'

# 2. Set the PC flip flop so that we try passing a logic '1' to MA
# The only way to set PC is to clear and then toggle
# Drive CV Direct Clear input active, check both outputs
vector='----1-011111111110---11111--11111111'
# Drive CV Direct Clear input inactive, check both outputs
vector='----1-011111111111---111110101111111'

#       AAAAAAAAAAAAAAAAAABBBBBBBBBBBBBBBBBB
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Now toggle it to set
# 1.1 Drive the DE Level Input active, check for no change on the outputs
vector='----1-011111111111---101110111111111'
# 1.2 Drive the DD Pulse Input active, flip-flip should be set
vector='----1-011111111111---001111011111111'
# 1.3 Drive the DD Pulse Input inactive, flip-flip should stay set
vector='----1-011111111111---101111011111111'
# 1.4 Drive the DE Level Input inactive, check for no change on the outputs
vector='----1-011111111111---111111011111111'

# 3. Clock PC into MA with falling edge on CM
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive CM active, check both outputs
vector='----0-111101111111---111111011111111'
# Drive CM inactive, check both outputs
vector='----0-111111111111---111111011111111'

# 4. Clear the PC flip flop and set the MA so that we can try passing
#    a logic '0' to MA from the PC
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive CV Direct Clear input active, check both outputs
vector='-------11111111110---11111--11111111'
# Drive CV Direct Clear input inactive, check both outputs
vector='-------11111111111---111110101111111'
# Drive the CR Level Input active
vector='-------11111101111---11111--11111111'
# Drive the CP Pulse Input active, MA flip-flip should be set
vector='----0-111111001111---01111--11111111'

# 5. Clock PC into MA with falling edge on CM
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive CM active, check both outputs
vector='---110011101111111---111110111111111'
# Drive CM inactive, check both outputs
vector='---110011111111111---111110111111111'


