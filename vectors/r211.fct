# Test for R211, Memory Address(MA), Memory Buffer(MB) & Program Counter(PC)
#
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# ! DO NOT TEST THE R211 IN AN UNMODIFIED BRS-TESTER  !
# ! PINS BA & BB ARE SIGNALS AND NOT +10/-15 RAILS    !
# ! AT BEST, YOU'LL BLOW THE 10V FUSE.                !
# ! FOR NOW, ONE OF THESE DCDs IS NOT TESTED          !
# ! SEE END OF THIS FILE FOR MODIFICATION DETAILS     !
# !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

# First test the indpendant inputs to the flip flops.
# Then test the inter-register transfers such as MB->PC, MB->MA, PC->MB etc

# To support transfer of MB -> PC:
# Output of the MB flip-flop serves as one of the level input(s) to the PC flip-flop
# To support transfer of PC -> MB:
# Output of the PC flip-flop serves as one of the level input(s) to the MB flip-flop
#
# A logic 1 = -3V and a logic 0 = 0V
# The Flip-Flops will be in an unknown state until after step 2
# All functions verified but the input current definitions may need adjustments




# -3V = Logic '1'
#  0V = Logic '0'
# Define the limits when testing inputs
# Inputs are 11mA load at gnd; Refer F-85 PDP-8 Users Handbook
# input-current-low (current at logic '0')
# input-current-high (current at logic '1')
input-current-low='-1.0mA'
input-current-high='-11.0mA'
input-current-margin='11.0mA'
input-voltage-low='-3700mV'
input-voltage-high='-50mV'

# Define how much current the outputs can sink
# 11mA on the 0 Output and 13mA on the 1 Output
output-drive-strength='11mA'

# The 'config' key describes how the tested board has it connections.
#
# 'p' - power pin, do nothing
# 'i' - input pin on tested board
# 'o' - output pin on tested board
# 'O' - output pin on tested board, open collector
# 'd' - pull down net on tested board
# 'g' - pin should be grounded on tested board
# '-' - pin should not be used, don't care and it will be electrically disconnected


#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
config='pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Hold all of the control inputs inactive, ignore the outputs
vector='-------11111111111---11111--11111111'

##################################################################
################  MA Flip Flop Independant Tests  ################
##################################################################
# Let's clear the MA flip-flop with the CJ direct clear input
# Drive CJ Direct Clear input active, check both outputs
vector='----1-001111111111---11111--11111111'
# Drive CJ Direct Clear input inactive, check both outputs
vector='----1-011111111111---11-11--11111111'

#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# 1.1 Drive the CR Level Input active, check for no change on the outputs
vector='-------11111101111---10111--11111111'
# 1.2 Drive the CP Pulse Input active, flip-flip should be set
vector='----0-111111001111---00111--11111111'
# 1.3 Drive the CP Pulse Input inactive, flip-flip should stay set
vector='----0-111111101111---10111--11111111'
# 1.4 Drive the CR Level Input inactive, check for no change on the outputs
vector='----0-111111111111---10111--11111111'
# 1.1 Drive the !CR Level Input active, check for no change on the outputs
vector='----0-111111111111---11111--11111111'
# 1.2 Drive the CP Pulse Input active, flip-flip should be cleared
vector='----1-011111011111---01111--11111111'
# 1.3 Drive the CP Pulse Input inactive, flip-flip should stay cleared
vector='----1-011111111111---11111--11111111'
# 1.4 Drive the !CR Level Input inactive, check for no change on the outputs
vector='----1-011111111111---11111--11111111'

#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Let's set the MA flip-flop with the CK direct clear input
vector='----1-011111111111---10111--11111111'
# Drive CK Direct Set inpput active, check both outputs
vector='----0-110111111111---11111--11111111'
# Drive CK Direct Set input inactive, check both outputs
vector='----0-111111111111---11-11--11111111'

# Let's clear the MA flip-flop with the CL direct clear input
vector='----0-111111111111---10111--11111111'
# Drive CL Direct Clear input active, check both outputs
vector='----1-011011111111---11111--11111111'
# Drive CL Direct Clear input inactive, check both outputs
vector='----1-011111111111---11-11--11111111'


##################################################################
################  PC Flip Flop Independant Tests  ################
##################################################################
# Let's clear the PC flip-flop with the direct clear input
# Drive CV Direct Clear input active, check both outputs
vector='-------11111111110---11111--11111111'
# Drive CV Direct Clear input inactive, check both outputs
vector='-------11111111111---111110101111111'

#       AAAAAAAAAAAAAAAAAABBBBBBBBBBBBBBBBBB
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Now toggle it to set
# 1.1 Drive the DE Level Input active, check for no change on the outputs
vector='-------11111111111---101110111111111'
# 1.2 Drive the DD Pulse Input active, flip-flip should be set
vector='-------11111111111---001111011111111'
# 1.3 Drive the DD Pulse Input inactive, flip-flip should stay set
vector='-------11111111111---101111011111111'
# 1.4 Drive the DE Level Input inactive, check for no change on the outputs
vector='-------11111111111---111111011111111'
# 1.1 Drive the DE Level Input active, check for no change on the outputs
vector='-------11111111111---101111011111111'
# 1.2 Drive the DD Pulse Input active, flip-flip should be cleared
vector='-------11111111111---001110111111111'
# 1.3 Drive the DD Pulse Input inactive, flip-flip should stay cleared
vector='-------11111111111---101110111111111'
# 1.4 Drive the DE Level Input inactive, check for no change on the outputs
vector='-------11111111111---101110111111111'

# Single DCD Gate for setting PC flip flop.
# 6. Clock SR into PC (setting it)
#    Note: Hardware is modified to allow card pin DB to ALSO be driven by CP.
#          Ignore the value that will simulataneously be clocked into MA
#
#       CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#       ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config'pppooooiiiiiiiiiiipppiiiiiooiiiiiiii'
# Drive the DF Level Input active, check for no change on the outputs
vector='---1-0-11111111111---11011--11111111'
# Drive DB(via CP channel) active, check both outputs
vector='---1-0-11111011111---11011--11111111'
# Drive DB(via CP channel) inactive, check both outputs
vector='---1-0-11111111111---110111011111111'
# Drive the DF Level Input inactive, check for no change on the outputs
vector='---1-0-11111111111---111111011111111'


#################################################################
################  MB Flip Flop Independant Tests ################
#################################################################

####################################################################
# Testing Toggle DCD Input CLK: DH   Level inputs: DJ
####################################################################
