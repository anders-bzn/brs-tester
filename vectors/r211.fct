###############################################################
################  Flip Flop Output Load Tests  ################
###############################################################

## MB
#             CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#             ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#             pppooooi--iiiiiiiipppiiiiiooiiiiiiii
output-drive='-------1--11111101---11111--11111111'
# Drive CU Direct Clear input active
output-drive='-----L-1--11111111---11111--11111111'
# Drive CT Direct Set input active
output-drive='---L---1--11111011---11111--11111111'

## PC
#             CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#             ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#config      'pppooooi--iiiiiiiipppiiiiiooiiiiiiii'
# Drive DA(via CS channel) active to copy MB->PC
output-drive='-------1--11111111---11111--11111111'
# Drive DA(via CS channel) inactive
output-drive='-------1--11110111---11111--11111111'
output-drive='-------1--11111111---11111-L11111111'

#             CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#             ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#             pppooooi--iiiiiiiipppiiiiiooiiiiiiii
# Set all inputs to inactive and use direct set and clear to configure flip-flop
# Drive CV Direct Set input active
output-drive='-------1--11111111---11111--11111111'
# Reset PC (CV direct clear) and Measure '1' output
output-drive='-------1--11111110---11111L-11111111'


# # Toggle the output with complement input(DD) and measure the '1' output
# output-drive='-------1--11111111---10111--11111111'
# # 1.2 Drive the DD Pulse Input active, flip-flip should be set
# output-drive='-------1--11111111---00111-L11111111'
# # 1.3 Drive the DD Pulse Input inactive, flip-flip should stay set
# output-drive='-------1--11111111---10111-L11111111'
# # 1.4 Drive the DE Level Input inactive, check for no change on the outputs
# output-drive='-------1--11111111---11111-L11111111'

## MA
#             CCCCCCCCCCCCCCCCCCDDDDDDDDDDDDDDDDDD
#             ABCDEFHJKLMNPRSTUVABCDEFHJKLMNPRSTUV
#             pppooooi--iiiiiiiipppiiiiiooiiiiiiii
output-drive='------00--11111111---11111--11111111'
# Drive CJ Direct Clear input inactive, check both outputs
output-drive='------L1--11111111---11111--11111111'

# Drive the CR Level Input active
output-drive='-------1--11101111---10111--11111111'
# Drive the CP Pulse Input active, flip-flip should be set
output-drive='----0--1--11001111---00111--11111111'
# Drive the CP Pulse Input inactive, flip-flip should stay set
output-drive='----0--1--11101111---10111--11111111'
# Drive the CR Level Input inactive, check for no change on the outputs
output-drive='----L--1--11111111---10111--11111111'

# output-drives-strength defines how much current the outputs can sink.
# This is a value is what the tester will load the output with.
output-drive-strength='18mA'

# Those two values will define the voltage drop over the transistor compared to ground. First
# the nominal value and then a margin that defines how much the value could diff from that.
output-voltage-high='-150mV'
output-voltage-margin='100mV'


####################################################################################
#
# Making an adapter for testing pin DA
#
# The R211 has only one unused pin, CS.
# Pins DA & DB are signals rather than power supplies
#
# The following instructions allow you to build an interposing board between the
# brs-tester and connector board.
#
# Build details:
#
# Taking a spare connector PCB, cut the following tracks:
# 1. Cut track from JP3 (on the -> Tester side) to BA2
# 2. Cut track from JP3 (on the -> Tester side) to BB2
# 3. Jumper BB2 to BC2
# 4. Jumper BA2 to AS2
